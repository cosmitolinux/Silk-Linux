/*
 * commands.c — sk Command Implementations
 * Part of the Silk Linux Project
 *
 * Implements: sk_install, sk_remove, sk_search, sk_info, sk_list
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include "../include/silk.h"
#include "../include/pm_detect.h"
#include "../include/output.h"

#define CMD_BUF 1024

static int confirm_action(const char *action, const char *pkg) {
    printf("\n");
    silk_warn("About to %s: %s", action, pkg);
    printf("  Continue? [y/N] ");
    fflush(stdout);
    char c = getchar();
    printf("\n");
    return (c == 'y' || c == 'Y');
}

static int run_cmd(const char *cmd, int dry_run) {
    if (dry_run) {
        silk_info("[DRY RUN] Would execute: %s", cmd);
        return 0;
    }
    int ret = system(cmd);
    return (ret == 0) ? 0 : 1;
}

int sk_install(PackageManager pm, const char *pkg,
               int dry_run, int confirm) {
    char cmd[CMD_BUF];
    pm_build_install_cmd(pm, pkg, cmd, sizeof(cmd));

    if (!cmd[0]) {
        silk_err("No install command available for this package manager.");
        return 1;
    }

    silk_info("Installing: %s", pkg);

    if (confirm && !dry_run) {
        if (!confirm_action("install", pkg)) {
            silk_warn("Aborted.");
            return 0;
        }
    }

    int ret = run_cmd(cmd, dry_run);
    if (ret == 0) {
        silk_ok("Successfully installed: %s", pkg);
    } else {
        silk_err("Failed to install: %s", pkg);
    }
    return ret;
}

int sk_remove(PackageManager pm, const char *pkg,
              int purge, int dry_run, int confirm) {
    char cmd[CMD_BUF];
    pm_build_remove_cmd(pm, pkg, purge, cmd, sizeof(cmd));

    if (!cmd[0]) {
        silk_err("No remove command available for this package manager.");
        return 1;
    }

    silk_info("Removing: %s%s", pkg, purge ? " (purge)" : "");

    if (confirm && !dry_run) {
        if (!confirm_action("remove", pkg)) {
            silk_warn("Aborted.");
            return 0;
        }
    }

    int ret = run_cmd(cmd, dry_run);
    if (ret == 0) {
        silk_ok("Successfully removed: %s", pkg);
    } else {
        silk_err("Failed to remove: %s", pkg);
    }
    return ret;
}

int sk_search(PackageManager pm, const char *query) {
    char cmd[CMD_BUF];
    pm_build_search_cmd(pm, query, cmd, sizeof(cmd));

    if (!cmd[0]) {
        silk_err("No search command available for this package manager.");
        return 1;
    }

    silk_info("Searching for: %s", query);
    printf("\n");
    return system(cmd);
}

int sk_info(PackageManager pm, const char *pkg) {
    char cmd[CMD_BUF];
    pm_build_info_cmd(pm, pkg, cmd, sizeof(cmd));

    if (!cmd[0]) {
        silk_err("No info command available for this package manager.");
        return 1;
    }

    silk_info("Package info: %s", pkg);
    printf("\n");
    return system(cmd);
}

int sk_list(PackageManager pm) {
    char cmd[CMD_BUF];

    switch (pm) {
        case PM_PACMAN:  snprintf(cmd, sizeof(cmd), "pacman -Q");          break;
        case PM_APT:     snprintf(cmd, sizeof(cmd), "apt list --installed");break;
        case PM_DNF:     snprintf(cmd, sizeof(cmd), "dnf list installed"); break;
        case PM_ZYPPER:  snprintf(cmd, sizeof(cmd), "zypper packages --installed-only"); break;
        case PM_APK:     snprintf(cmd, sizeof(cmd), "apk list --installed");break;
        default:
            silk_err("No list command available for this package manager.");
            return 1;
    }

    silk_info("Installed packages:");
    printf("\n");
    return system(cmd);
}







# LOGGIN'
/*
 * output.c — Silk Structured Output
 * Part of the Silk Linux Project
 *
 * Provides color-coded, prefixed terminal output:
 *   [OK]   — success (green)
 *   [ERR]  — failure (red)
 *   [WARN] — warning (yellow)
 *   [INFO] — status  (blue)
 */

#include <stdio.h>
#include <stdarg.h>
#include "../include/output.h"

/* ANSI color codes */
#define ANSI_RESET   "\033[0m"
#define ANSI_GREEN   "\033[0;32m"
#define ANSI_RED     "\033[0;31m"
#define ANSI_YELLOW  "\033[0;33m"
#define ANSI_BLUE    "\033[0;34m"
#define ANSI_BOLD    "\033[1m"

static int use_color = 1; /* can be disabled via NO_COLOR env var */

void output_init(void) {
    /* respect NO_COLOR standard — https://no-color.org */
    if (getenv("NO_COLOR") != NULL) {
        use_color = 0;
    }
}

void silk_ok(const char *fmt, ...) {
    va_list args;
    va_start(args, fmt);
    if (use_color)
        printf(ANSI_GREEN ANSI_BOLD "[OK]" ANSI_RESET "   ");
    else
        printf("[OK]   ");
    vprintf(fmt, args);
    printf("\n");
    va_end(args);
}

void silk_err(const char *fmt, ...) {
    va_list args;
    va_start(args, fmt);
    if (use_color)
        fprintf(stderr, ANSI_RED ANSI_BOLD "[ERR]" ANSI_RESET "  ");
    else
        fprintf(stderr, "[ERR]  ");
    vfprintf(stderr, fmt, args);
    fprintf(stderr, "\n");
    va_end(args);
}

void silk_warn(const char *fmt, ...) {
    va_list args;
    va_start(args, fmt);
    if (use_color)
        printf(ANSI_YELLOW ANSI_BOLD "[WARN]" ANSI_RESET " ");
    else
        printf("[WARN] ");
    vprintf(fmt, args);
    printf("\n");
    va_end(args);
}

void silk_info(const char *fmt, ...) {
    va_list args;
    va_start(args, fmt);
    if (use_color)
        printf(ANSI_BLUE ANSI_BOLD "[INFO]" ANSI_RESET " ");
    else
        printf("[INFO] ");
    vprintf(fmt, args);
    printf("\n");
    va_end(args);
}



