# PM
/*
 * pm_detect.c — Host Package Manager Detection
 * Part of the Silk Linux Project
 *
 * Detects which package manager is available on the host system
 * by checking for known binaries in $PATH.
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include "../include/pm_detect.h"
#include "../include/output.h"

/* check if a binary exists in PATH */
static int binary_exists(const char *name) {
    char path[512];
    snprintf(path, sizeof(path), "which %s > /dev/null 2>&1", name);
    return (system(path) == 0);
}

PackageManager pm_detect(void) {
    if (binary_exists("pacman"))  return PM_PACMAN;
    if (binary_exists("apt"))     return PM_APT;
    if (binary_exists("dnf"))     return PM_DNF;
    if (binary_exists("zypper"))  return PM_ZYPPER;
    if (binary_exists("apk"))     return PM_APK;
    return PM_UNKNOWN;
}

const char *pm_name(PackageManager pm) {
    switch (pm) {
        case PM_PACMAN:  return "pacman (Arch)";
        case PM_APT:     return "apt (Debian/Ubuntu)";
        case PM_DNF:     return "dnf (Fedora/RHEL)";
        case PM_ZYPPER:  return "zypper (openSUSE)";
        case PM_APK:     return "apk (Alpine)";
        default:         return "unknown";
    }
}

/*
 * Build the install command string for the detected PM.
 * Caller is responsible for the buffer.
 */
void pm_build_install_cmd(PackageManager pm, const char *pkg,
                          char *buf, size_t bufsz) {
    switch (pm) {
        case PM_PACMAN:
            snprintf(buf, bufsz, "pacman -S --noconfirm %s", pkg);
            break;
        case PM_APT:
            snprintf(buf, bufsz, "apt install -y %s", pkg);
            break;
        case PM_DNF:
            snprintf(buf, bufsz, "dnf install -y %s", pkg);
            break;
        case PM_ZYPPER:
            snprintf(buf, bufsz, "zypper install -y %s", pkg);
            break;
        case PM_APK:
            snprintf(buf, bufsz, "apk add %s", pkg);
            break;
        default:
            buf[0] = '\0';
            break;
    }
}

void pm_build_remove_cmd(PackageManager pm, const char *pkg,
                         int purge, char *buf, size_t bufsz) {
    switch (pm) {
        case PM_PACMAN:
            snprintf(buf, bufsz, "pacman -R%s --noconfirm %s",
                     purge ? "ns" : "s", pkg);
            break;
        case PM_APT:
            snprintf(buf, bufsz, "apt %s -y %s",
                     purge ? "purge" : "remove", pkg);
            break;
        case PM_DNF:
            snprintf(buf, bufsz, "dnf remove -y %s", pkg);
            break;
        case PM_ZYPPER:
            snprintf(buf, bufsz, "zypper remove -y %s", pkg);
            break;
        case PM_APK:
            snprintf(buf, bufsz, "apk del %s", pkg);
            break;
        default:
            buf[0] = '\0';
            break;
    }
}

void pm_build_search_cmd(PackageManager pm, const char *query,
                         char *buf, size_t bufsz) {
    switch (pm) {
        case PM_PACMAN:  snprintf(buf, bufsz, "pacman -Ss %s", query);   break;
        case PM_APT:     snprintf(buf, bufsz, "apt search %s", query);   break;
        case PM_DNF:     snprintf(buf, bufsz, "dnf search %s", query);   break;
        case PM_ZYPPER:  snprintf(buf, bufsz, "zypper search %s", query);break;
        case PM_APK:     snprintf(buf, bufsz, "apk search %s", query);   break;
        default:         buf[0] = '\0'; break;
    }
}

void pm_build_info_cmd(PackageManager pm, const char *pkg,
                       char *buf, size_t bufsz) {
    switch (pm) {
        case PM_PACMAN:  snprintf(buf, bufsz, "pacman -Si %s", pkg);  break;
        case PM_APT:     snprintf(buf, bufsz, "apt show %s", pkg);    break;
        case PM_DNF:     snprintf(buf, bufsz, "dnf info %s", pkg);    break;
        case PM_ZYPPER:  snprintf(buf, bufsz, "zypper info %s", pkg); break;
        case PM_APK:     snprintf(buf, bufsz, "apk info %s", pkg);    break;
        default:         buf[0] = '\0'; break;
    }
}



# Silk PKGS
/*
 * sk.c — Silk Package Manager Entry Point
 * Part of the Silk Linux Project
 *
 * License: MIT
 * Language: C
 *
 * Commands:
 *   sk g <pkg>     — get / install a package
 *   sk r <pkg>     — remove a package
 *   sk s <query>   — search packages
 *   sk i <pkg>     — package info
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include "../include/silk.h"
#include "../include/pm_detect.h"
#include "../include/output.h"

#define SK_VERSION "0.172-testing"

static void print_usage(void) {
    silk_info("Silk Package Manager — sk v" SK_VERSION);
    printf("\n");
    printf("  Usage: sk <command> [package]\n");
    printf("\n");
    printf("  Commands:\n");
    printf("    g <package>    Install a package\n");
    printf("    r <package>    Remove a package\n");
    printf("    s <query>      Search for a package\n");
    printf("    i <package>    Show package info\n");
    printf("    list           List installed packages\n");
    printf("\n");
    printf("  Flags:\n");
    printf("    --purge        Remove config files too (use with r)\n");
    printf("    --dry-run      Preview changes without applying\n");
    printf("    --no-confirm   Skip confirmation prompts\n");
    printf("    --version      Print version\n");
    printf("\n");
}

static void print_version(void) {
    printf("sk version " SK_VERSION "\n");
    printf("Silk Linux Project — https://silklinux.org\n");
}

int main(int argc, char *argv[]) {
    if (argc < 2) {
        print_usage();
        return 0;
    }

    /* flags */
    int flag_purge    = 0;
    int flag_dry_run  = 0;
    int flag_confirm  = 1;

    for (int i = 1; i < argc; i++) {
        if (strcmp(argv[i], "--purge")      == 0) flag_purge   = 1;
        if (strcmp(argv[i], "--dry-run")    == 0) flag_dry_run = 1;
        if (strcmp(argv[i], "--no-confirm") == 0) flag_confirm = 0;
        if (strcmp(argv[i], "--version")    == 0) { print_version(); return 0; }
    }

    const char *cmd = argv[1];
    const char *pkg = (argc >= 3) ? argv[2] : NULL;

    /* detect the host package manager */
    PackageManager pm = pm_detect();
    if (pm == PM_UNKNOWN) {
        silk_err("Could not detect a supported package manager on this system.");
        silk_info("Supported: pacman, apt, dnf, zypper, apk");
        return 1;
    }

    silk_info("Detected package manager: %s", pm_name(pm));

    /* dispatch command */
    if (strcmp(cmd, "g") == 0) {
        if (!pkg) { silk_err("Usage: sk g <package>"); return 1; }
        return sk_install(pm, pkg, flag_dry_run, flag_confirm);
    }
    else if (strcmp(cmd, "r") == 0) {
        if (!pkg) { silk_err("Usage: sk r <package>"); return 1; }
        return sk_remove(pm, pkg, flag_purge, flag_dry_run, flag_confirm);
    }
    else if (strcmp(cmd, "s") == 0) {
        if (!pkg) { silk_err("Usage: sk s <query>"); return 1; }
        return sk_search(pm, pkg);
    }
    else if (strcmp(cmd, "i") == 0) {
        if (!pkg) { silk_err("Usage: sk i <package>"); return 1; }
        return sk_info(pm, pkg);
    }
    else if (strcmp(cmd, "list") == 0) {
        return sk_list(pm);
    }
    else {
        silk_err("Unknown command: %s", cmd);
        print_usage();
        return 1;
    }
}


